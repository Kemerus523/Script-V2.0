local MIN_BUY, MAX_BUY = 1, 100

local function updateSlider(val)
	val = math.clamp(math.round(val), MIN_BUY, MAX_BUY)
	autoBuyAmount = val
	sliderValLbl.Text = tostring(val)
	local pct = (val - MIN_BUY) / (MAX_BUY - MIN_BUY)
	sliderFill.Size = UDim2.new(pct, 0, 1, 0)
	sliderThumb.Position = UDim2.new(pct, 0, 0.5, 0)
end
updateSlider(1)

local function getSliderVal(inputX)
	local trackX   = sliderTrack.AbsolutePosition.X
	local trackW   = sliderTrack.AbsoluteSize.X
	local pct      = math.clamp((inputX - trackX) / trackW, 0, 1)
	return MIN_BUY + pct * (MAX_BUY - MIN_BUY)
end

sliderThumb.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		sliderDragging = true
		dragging = false
	end
end)

sliderTrack.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		sliderDragging = true
		dragging = false
		updateSlider(getSliderVal(input.Position.X))
	end
end)

UIS.InputChanged:Connect(function(input)
	if sliderDragging and (
		input.UserInputType == Enum.UserInputType.MouseMovement or
		input.UserInputType == Enum.UserInputType.Touch) then
		updateSlider(getSliderVal(input.Position.X))
	end
end)


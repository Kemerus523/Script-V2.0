-- ================================================
-- INVENTORY SYSTEM
-- ================================================
local inventory = {
	Water          = 0,
	BlockSugarBag  = 0,
	Gelatin        = 0,
}

local INVENTORY_DISPLAY = {
	{ key = "Water",         label = "Water",           icon = "💧" },
	{ key = "BlockSugarBag", label = "Block Sugar Bag", icon = "🍬" },
	{ key = "Gelatin",       label = "Gelatin",         icon = "🟡" },
}

local inventoryLabels = {}

local function updateInventoryLabel(key)
	if inventoryLabels[key] then
		inventoryLabels[key].Text = tostring(inventory[key])
	end
end

local function addInventoryItem(itemKey, amount)
	amount = amount or 1
	if inventory[itemKey] ~= nil then
		inventory[itemKey] = inventory[itemKey] + amount
		updateInventoryLabel(itemKey)
	end
end

local function resetInventory()
	for key in pairs(inventory) do
		inventory[key] = 0
		updateInventoryLabel(key)
	end
end

-- ================================================
-- AUTO BUY v2 (logic baru dari source)
-- ================================================
local autoBuyEnabled = false
local autoBuyAmount  = 50

-- Remote Buy
local MS_RemoteBuy = (ReplicatedStorage:FindFirstChild("RemoteEvents")
	and ReplicatedStorage.RemoteEvents:FindFirstChild("StorePurchase"))

-- Item names sesuai server
local BUY_ITEMS = {
	{ id = "Water",          key = "Water"         },
	{ id = "Gelatin",        key = "Gelatin"        },
	{ id = "Sugar Block Bag",key = "BlockSugarBag"  },
}

-- ================================================
-- AUTO SELL (logic baru dari source)
-- ================================================
local autoSellEnabled = false
local autoSellRunning = false

-- Nama bag (sesuai tool di inventory player)
local MS_TN = {
	smallBag  = {"small marshmallow bag","small marshallov bag","smallmarshmallowbag","marshmallow kecil","small bag"},
	mediumBag = {"medium marshmallow bag","medium marshallov bag","mediummarshmallowbag","marshmallow sedang","medium bag"},
	largeBag  = {"large marshmallow bag","large marshallov bag","largemarshmallowbag","marshmallow besar","large bag"},
}

-- Proximity Prompt cache (untuk efisiensi)
local MS_promptCache = {}

local function MS_patchPr(o)
	pcall(function()
		o.HoldDuration       = 0
		o.RequiresLineOfSight = false
	end)
end

-- Patch semua prompt yang masuk/keluar workspace
workspace.DescendantAdded:Connect(function(o)
	if o:IsA("ProximityPrompt") then
		MS_patchPr(o)
		MS_promptCache[#MS_promptCache + 1] = o
	end
end)

workspace.DescendantRemoving:Connect(function(o)
	if o:IsA("ProximityPrompt") then
		for i = #MS_promptCache, 1, -1 do
			if MS_promptCache[i] == o then
				table.remove(MS_promptCache, i)
				break
			end
		end
	end
end)

-- Scan awal workspace setelah 2 detik
task.delay(2, function()
	local tmp = {}
	for _, o in ipairs(workspace:GetDescendants()) do
		if o:IsA("ProximityPrompt") then
			MS_patchPr(o)
			tmp[#tmp + 1] = o
		end
		task.wait()
	end
	MS_promptCache = tmp
end)

local function MS_matchTool(n, list)
	for _, v in ipairs(list) do
		if n:find(v, 1, true) then return true end
	end
	return false
end

local function MS_EquipTool(list)
	local ch = plr.Character
	local bp = plr:FindFirstChild("Backpack")
	if not ch then return false end
	-- Cek apakah sudah equipped
	for _, o in ipairs(ch:GetChildren()) do
		if o:IsA("Tool") and MS_matchTool(o.Name:lower(), list) then
			return true
		end
	end
	-- Coba equip dari Backpack
	if bp then
		for _, o in ipairs(bp:GetChildren()) do
			if o:IsA("Tool") and MS_matchTool(o.Name:lower(), list) then
				if pcall(function() o.Parent = ch end) then
					task.wait(0.35)
					return true
				end
			end
		end
	end
	return false
end

local function MS_FirePrompt(pr)
	if not pr or not pr.Parent then return end
	MS_patchPr(pr)
	-- Coba berbagai cara fire prompt
	if fireproximityprompt then
		if pcall(function() fireproximityprompt(pr) end) then task.wait(0.18); return end
	end
	if pcall(function() ProximityPromptService:TriggerPrompt(pr) end) then
		task.wait(0.18); return
	end
	pcall(function()
		pr:InputHoldBegin()
		task.wait(0.12)
		pr:InputHoldEnd()
	end)
	task.wait(0.18)
end

local function MS_GetLamontPrompt()
	-- Coba path langsung dulu
	local ok, r = pcall(function()
		return workspace.Folders.NPCs["Lamont Bell"].UpperTorso.ProximityPrompt
	end)
	if ok and r then return r end
	-- Fallback: cari di cache berdasarkan nama path
	for _, v in ipairs(MS_promptCache) do
		if v and v.Parent then
			local path = v:GetFullName():lower()
			if path:find("lamont") or path:find("bell") then
				return v
			end
		end
	end
	return nil
end

-- Fungsi Buy utama (dipanggil loop / manual)
local function doBuyAll(n)
	n = math.clamp(math.floor(tonumber(n) or 50), 1, 200)
	if not MS_RemoteBuy then return 0 end
	local bought = 0
	for _, item in ipairs(BUY_ITEMS) do
		for i = 1, n do
			local success = pcall(function()
				MS_RemoteBuy:FireServer(item.id)
			end)
			if success then
				addInventoryItem(item.key, 1)
				bought = bought + 1
			end
			task.wait(0.28)
		end
	end
	return bought
end

-- Fungsi Sell utama
local function doSellAll()
	local pr = MS_GetLamontPrompt()
	if not pr then return 0 end
	local sold = 0
	for _, list in ipairs({ MS_TN.largeBag, MS_TN.mediumBag, MS_TN.smallBag }) do
		for _ = 1, 999 do
			if MS_EquipTool(list) then
				MS_FirePrompt(pr)
				task.wait(0.55)
				sold = sold + 1
			else
				break
			end
		end
	end
	return sold
end

-- ================================================
-- AUTO MASAK SYSTEM
-- ================================================
local autoCookEnabled  = false
local autoCookRunning  = false
local cookStatusLbl    = nil   -- label referensi, diisi saat GUI dibuat

-- Timing sesuai source (detik)
local COOK_TIMING = {
	water   = 22,
	sugar   = 1,
	gelatin = 47,
	empty   = 2,
	rest    = 1,
}

-- Nama tool yang dicari (lower-case flexible)
local COOK_TOOL_NAMES = {
	water   = {"water", "air", "water bucket", "bucket of water", "air bucket",
	           "water container", "air minum"},
	sugar   = {"sugar block bag", "sugar block", "gula", "sugar bag",
	           "sugar sack", "sugar cube", "gula block"},
	gelatin = {"gelatin", "gelatin bag", "gelatin block", "gelatin sack",
	           "gelatin cube", "agar"},
	empty   = {"emptybag", "empty bag", "empty back", "emptyback",
	           "kosong", "empty sack", "kantong kosong"},
}

-- Cache ProximityPrompt untuk performa
local cookPromptCache  = {}
local cookLastScan     = 0

-- Scan workspace untuk prompt (cache 2 detik)
local function cookFindNearestPrompt(maxRange)
	local ch = plr.Character
	if not ch then return nil end
	local root = ch:FindFirstChild("HumanoidRootPart")
	if not root then return nil end

	local now = tick()
	if now - cookLastScan > 2 or #cookPromptCache == 0 then
		cookPromptCache = {}
		for _, obj in pairs(workspace:GetDescendants()) do
			if obj:IsA("ProximityPrompt") then
				table.insert(cookPromptCache, obj)
			end
		end
		cookLastScan = now
	end

	local playerPos  = root.Position
	local nearest    = nil
	local nearestDist = maxRange or 50

	for _, prompt in ipairs(cookPromptCache) do
		if prompt.Enabled then
			local parent    = prompt.Parent
			local promptPos = nil
			if parent and parent:IsA("BasePart") then
				promptPos = parent.Position
			elseif parent and parent:IsA("Attachment") then
				promptPos = parent.WorldPosition
			end
			if promptPos then
				local dist = (promptPos - playerPos).Magnitude
				local maxDist = maxRange or prompt.MaxActivationDistance
				if dist <= maxDist and dist < nearestDist then
					nearestDist = dist
					nearest     = prompt
				end
			end
		end
	end
	return nearest
end

-- Trigger ProximityPrompt dengan hold
local function cookTriggerPrompt(prompt)
	if not prompt then return false end
	local success = pcall(function()
		prompt:InputHoldBegin()
		task.wait(prompt.HoldDuration + 0.1)
		prompt:InputHoldEnd()
	end)
	if not success then
		-- fallback
		pcall(function() fireproximityprompt(prompt) end)
	end
	return success
end

-- Cari tool di Backpack / Character
local function cookScanTool(nameList)
	local bp   = plr:FindFirstChild("Backpack")
	local ch   = plr.Character
	local locs = {}
	if bp then table.insert(locs, bp) end
	if ch then table.insert(locs, ch) end

	for _, container in ipairs(locs) do
		for _, obj in ipairs(container:GetChildren()) do
			if obj:IsA("Tool") then
				for _, targetName in ipairs(nameList) do
					if string.find(string.lower(obj.Name), string.lower(targetName), 1, true) then
						return obj, (container == ch)
					end
				end
			end
		end
	end
	return nil, false
end

-- Equip tool dari Backpack ke Character
local function cookEquipTool(nameList)
	local tool, equipped = cookScanTool(nameList)
	if not tool then return false end
	if equipped then return true end
	pcall(function() tool.Parent = plr.Character end)
	task.wait(0.3)
	return true
end

-- Satu siklus masak lengkap
local function cookOneCycle()
	-- 1. Equip & tuang Water
	if cookEquipTool(COOK_TOOL_NAMES.water) then
		local pr = cookFindNearestPrompt(15)
		if pr then cookTriggerPrompt(pr) end
		task.wait(COOK_TIMING.water)
	end

	-- 2. Equip & tuang Sugar
	if cookEquipTool(COOK_TOOL_NAMES.sugar) then
		local pr = cookFindNearestPrompt(15)
		if pr then cookTriggerPrompt(pr) end
		task.wait(COOK_TIMING.sugar)
	end

	-- 3. Equip & tuang Gelatin
	if cookEquipTool(COOK_TOOL_NAMES.gelatin) then
		local pr = cookFindNearestPrompt(15)
		if pr then cookTriggerPrompt(pr) end
		task.wait(COOK_TIMING.gelatin)
	end

	-- 4. Equip Empty Bag & ambil hasil
	if cookEquipTool(COOK_TOOL_NAMES.empty) then
		local pr = cookFindNearestPrompt(15)
		if pr then cookTriggerPrompt(pr) end
		task.wait(COOK_TIMING.empty)
	end

	-- 5. Jeda antar siklus
	task.wait(COOK_TIMING.rest)
end

-- Loop utama Auto Masak
local function cookMainLoop()
	while autoCookEnabled do
		autoCookRunning = true
		if cookStatusLbl then
			cookStatusLbl.Text       = "⏳ Masak berjalan..."
			cookStatusLbl.TextColor3  = Color3.fromRGB(255, 200, 40)
		end

		pcall(cookOneCycle)

		if cookStatusLbl and autoCookEnabled then
			cookStatusLbl.Text       = "✅ Siklus selesai! Lanjut..."
			cookStatusLbl.TextColor3  = Color3.fromRGB(34, 187, 85)
		end
	end
	autoCookRunning = false
	if cookStatusLbl then
		cookStatusLbl.Text       = "Status: OFF"
		cookStatusLbl.TextColor3  = Color3.fromRGB(85, 85, 110)
	end
end

-- ================================================
-- DELETE OBJECT SYSTEM
-- ================================================
local deleteStack  = {}
local MAX_UNDO     = 50
local deleteConn   = nil
local undoCountLbl = nil

local function savePartData(part)
	return {
		part   = part,
		parent = part.Parent,
		cframe = part:IsA("BasePart") and part.CFrame or nil,
		properties = {
			Anchored     = part:IsA("BasePart") and part.Anchored     or nil,
			CanCollide   = part:IsA("BasePart") and part.CanCollide   or nil,
			Transparency = part:IsA("BasePart") and part.Transparency or nil,
		},
	}
end

local function updateUndoLabel()
	if undoCountLbl then
		local n = #deleteStack
		undoCountLbl.Text = "Tersimpan: " .. n .. "/" .. MAX_UNDO
		undoCountLbl.TextColor3 = n > 0
			and Color3.fromRGB(40, 120, 255)
			or  Color3.fromRGB(85, 85, 110)
	end
end

local function deleteObject(part)
	if not part or not part.Parent then return end
	if part:IsDescendantOf(char)   then return end
	if part:IsA("Terrain")         then return end
	local data = savePartData(part)
	table.insert(deleteStack, data)
	if #deleteStack > MAX_UNDO then table.remove(deleteStack, 1) end
	part.Parent = nil
	updateUndoLabel()
end

local function undoDelete()
	if #deleteStack == 0 then return end
	local data = table.remove(deleteStack)
	pcall(function()
		data.part.Parent = data.parent
		if data.cframe and data.part:IsA("BasePart") then
			data.part.CFrame = data.cframe
		end
	end)
	updateUndoLabel()
end

local function setDeleteMode(enabled)
	state.DeleteMode = enabled
	if enabled then
		local mouse = plr:GetMouse()
		deleteConn = mouse.Button1Down:Connect(function()
			local target = mouse.Target
			if target then deleteObject(target) end
		end)
	else
		if deleteConn then deleteConn:Disconnect(); deleteConn = nil end
	end
end

UIS.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Enum.KeyCode.Z and state.DeleteMode then
		undoDelete()
	end
end)


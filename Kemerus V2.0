	ACCENT     = Color3.fromRGB(40, 120, 255),
	TEXT       = Color3.new(1, 1, 1),
	MUTED      = Color3.fromRGB(85, 85, 110),
	SUCCESS    = Color3.fromRGB(34, 187, 85),
	DANGER     = Color3.fromRGB(192, 60, 60),
	TOGGLE_OFF = Color3.fromRGB(30, 30, 46),
	TOGGLE_ON  = Color3.fromRGB(40, 120, 255),
	ORANGE     = Color3.fromRGB(255, 140, 30),
}


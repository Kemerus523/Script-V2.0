-- ================================================
-- AUTO SELL LOOP (jual setelah setiap buy round)
-- ================================================
task.spawn(function()
	while true do
		task.wait(4)
		if autoSellEnabled and not autoSellRunning then
			autoSellRunning = true
			statusSellLbl.Text      = "Status: ON  •  Selling..."
			statusSellLbl.TextColor3 = C.SELL_CLR
			task.spawn(function()
				local n = doSellAll()
				if autoSellEnabled then
					statusSellLbl.Text      = "Status: ON  •  Sold " .. n
					statusSellLbl.TextColor3 = C.SUCCESS
				else
					statusSellLbl.Text      = "Status: OFF"
					statusSellLbl.TextColor3 = C.MUTED
				end
				autoSellRunning = false
			end)
		elseif not autoSellEnabled then
			statusSellLbl.Text      = "Status: OFF"
			statusSellLbl.TextColor3 = C.MUTED
		end
	end
end)

-- Speed Hack
local BASE_SPEED = 16
local SPEED_HACK = 48

local function applySpeed()
	if hum and hum.Parent then
		hum.WalkSpeed = state.SpeedHack and SPEED_HACK or BASE_SPEED
	end
end

plr.CharacterAdded:Connect(function(newChar)
	char = newChar
	hrp  = newChar:WaitForChild("HumanoidRootPart")
	hum  = newChar:WaitForChild("Humanoid")
	task.wait(0.5)
	applySpeed()
end)

-- Noclip
RunService.Stepped:Connect(function()
	if state.Noclip then
		for _, part in ipairs(char:GetDescendants()) do
			if part:IsA("BasePart") then part.CanCollide = false end
		end
	end
end)

-- Fly
local flyBody
local function startFly()
	flyBody          = Instance.new("BodyVelocity", hrp)
	flyBody.Velocity = Vector3.new(0,0,0)
	flyBody.MaxForce = Vector3.new(1e5,1e5,1e5)
end
local function stopFly()
	if flyBody then flyBody:Destroy() end
end

RunService.Heartbeat:Connect(function()
	if state.Fly then
		if not flyBody or not flyBody.Parent then startFly() end
		local cam = workspace.CurrentCamera
		flyBody.Velocity =
			cam.CFrame.LookVector * (UIS:IsKeyDown(Enum.KeyCode.W) and 60 or UIS:IsKeyDown(Enum.KeyCode.S) and -60 or 0)
			+ Vector3.new(0, UIS:IsKeyDown(Enum.KeyCode.Space) and 40 or UIS:IsKeyDown(Enum.KeyCode.LeftControl) and -40 or 0, 0)
	else
		stopFly()
	end
end)

-- ================================================
-- AIMBOT SYSTEM
-- ================================================
local Camera = workspace.CurrentCamera

local function getClosestTarget()
	local closestPlayer = nil
	local closestDist   = math.huge
	local screenCenter  = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

	for _, target in ipairs(Players:GetPlayers()) do
		if target ~= plr and target.Character then
			local targetHum = target.Character:FindFirstChildOfClass("Humanoid")
			if targetHum and targetHum.Health > 0 then
				local part = target.Character:FindFirstChild(aimbotTargetPart)
					or target.Character:FindFirstChild("HumanoidRootPart")
				if part then
					local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
					if onScreen then
						local dist2D = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
						if dist2D < closestDist then
							closestDist   = dist2D
							closestPlayer = part
						end
					end
				end
			end
		end
	end
	return closestPlayer
end

local aimbotHolding = false
UIS.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.UserInputType == Enum.UserInputType.MouseButton2 then
		aimbotHolding = true
	end
end)
UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton2 then
		aimbotHolding = false
	end
end)

RunService.RenderStepped:Connect(function()
	if not state.Aimbot then return end
	if not aimbotHolding then
		aimStatusLbl.Text      = "Status: ON  |  Target: " .. aimbotTargetPart .. "  |  Tahan RMB"
		aimStatusLbl.TextColor3 = C.MUTED
		return
	end
	local targetPart = getClosestTarget()
	if targetPart then
		local lookCF = CFrame.lookAt(Camera.CFrame.Position, targetPart.Position)
		Camera.CFrame = Camera.CFrame:Lerp(lookCF, 0.3)
		aimStatusLbl.Text      = "🔴 LOCKED: " .. targetPart.Parent.Name .. "  [" .. aimbotTargetPart .. "]"
		aimStatusLbl.TextColor3 = C.DANGER
	else
		aimStatusLbl.Text      = "Status: ON  |  Tidak ada target"
		aimStatusLbl.TextColor3 = C.MUTED
	end
end)

-- ================================================
-- ESP SYSTEM
-- ================================================
local espObjects = {}

local function createESP(target)
	if target == plr then return end
	if espObjects[target] then return end
	local targetChar = target.Character
	if not targetChar then return end
	local head = targetChar:FindFirstChild("Head")
	if not head then return end

	local billboard = Instance.new("BillboardGui")
	billboard.Name        = "KemerusESPName"
	billboard.Size        = UDim2.new(0, 140, 0, 36)
	billboard.StudsOffset = Vector3.new(0, 3, 0)
	billboard.AlwaysOnTop = true
	billboard.Adornee     = head
	billboard.Parent      = targetChar

	local nameLabel = Instance.new("TextLabel", billboard)
	nameLabel.Size                   = UDim2.new(1, 0, 1, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text                   = target.DisplayName .. "\n[" .. target.Name .. "]"
	nameLabel.TextColor3             = Color3.fromRGB(40, 200, 255)
	nameLabel.TextStrokeColor3       = Color3.new(0, 0, 0)
	nameLabel.TextStrokeTransparency = 0
	nameLabel.TextSize               = 13
	nameLabel.Font                   = Enum.Font.GothamBold

	espObjects[target] = { billboard = billboard }
end

local function removeESP(target)
	if espObjects[target] then
		pcall(function() espObjects[target].billboard:Destroy() end)
		espObjects[target] = nil
	end
end

local function clearAllESP()
	for target in pairs(espObjects) do removeESP(target) end
end

RunService.Heartbeat:Connect(function()
	if not state.ESP then clearAllESP(); return end
	for _, target in ipairs(Players:GetPlayers()) do
		if target ~= plr and target.Character then createESP(target) end
	end
	for target in pairs(espObjects) do
		if not target.Parent then removeESP(target) end
	end
end)

Players.PlayerRemoving:Connect(removeESP)

for _, target in ipairs(Players:GetPlayers()) do
	if target ~= plr then
		target.CharacterAdded:Connect(function()
			task.wait(1)
			if state.ESP then removeESP(target); createESP(target) end
		end)
	end
end

Players.PlayerAdded:Connect(function(target)
	target.CharacterAdded:Connect(function()
		task.wait(1)
		if state.ESP then removeESP(target); createESP(target) end
	end)
end)


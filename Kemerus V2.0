local buyRunning = false
buyMainBtn.MouseButton1Click:Connect(function()
	if buyRunning then return end
	buyRunning = true
	-- Animasi tekan
	TweenService:Create(buyMainBtn, TweenInfo.new(0.08), {BackgroundColor3 = Color3.fromRGB(25, 90, 200)}):Play()
	task.wait(0.08)
	TweenService:Create(buyMainBtn, TweenInfo.new(0.12), {BackgroundColor3 = C.ACCENT}):Play()

	statusBuyLbl.Text       = "Membeli x" .. autoBuyAmount .. "..."
	statusBuyLbl.TextColor3  = C.ACCENT
	buyMainBtn.Text         = "BUYING..."

	task.spawn(function()
		doBuyAll(autoBuyAmount)
		statusBuyLbl.Text       = "Selesai: beli x" .. autoBuyAmount .. " per item"
		statusBuyLbl.TextColor3  = C.SUCCESS
		buyMainBtn.Text         = "BUY  x" .. tostring(autoBuyAmount)
		task.wait(2)
		statusBuyLbl.Text       = "Siap beli"
		statusBuyLbl.TextColor3  = C.MUTED
		buyRunning = false
	end)
end)

-- Resize card
buyCard.Size = UDim2.new(1, 0, 0, 198)

-- ── Logic input angka ──
local function applyBuyAmount(val)
	local n = tonumber(val)
	if not n then n = autoBuyAmount end
	n = math.clamp(math.floor(n), MIN_BUY, MAX_BUY)
	autoBuyAmount    = n
	buyInputBox.Text = tostring(n)
	if buyMainBtn then
		buyMainBtn.Text = "BUY  x" .. tostring(n)
	end
	-- Highlight border hijau sesaat
	TweenService:Create(inputStroke, TweenInfo.new(0.15), {Color = C.SUCCESS}):Play()
	task.delay(0.8, function()
		TweenService:Create(inputStroke, TweenInfo.new(0.3), {Color = C.BORDER}):Play()
	end)
end

-- Konfirmasi saat fokus hilang atau Enter ditekan
buyInputBox.FocusLost:Connect(function(enterPressed)
	applyBuyAmount(buyInputBox.Text)
end)

-- Filter karakter — hanya angka boleh masuk
buyInputBox:GetPropertyChangedSignal("Text"):Connect(function()
	local cleaned = buyInputBox.Text:gsub("[^%d]", "")
	if cleaned ~= buyInputBox.Text then
		buyInputBox.Text = cleaned
	end
end)

-- Highlight border saat fokus
buyInputBox.Focused:Connect(function()
	TweenService:Create(inputStroke, TweenInfo.new(0.15), {Color = C.ACCENT}):Play()
end)

-- Tombol -
btnMinus.MouseButton1Click:Connect(function()
	local step = UIS:IsKeyDown(Enum.KeyCode.LeftShift) and 10 or 1
	applyBuyAmount(autoBuyAmount - step)
	TweenService:Create(btnMinus, TweenInfo.new(0.08), {BackgroundColor3 = C.BORDER}):Play()
	task.delay(0.1, function()
		TweenService:Create(btnMinus, TweenInfo.new(0.1), {BackgroundColor3 = C.BG3}):Play()
	end)
end)

-- Tombol +
btnPlus.MouseButton1Click:Connect(function()
	local step = UIS:IsKeyDown(Enum.KeyCode.LeftShift) and 10 or 1
	applyBuyAmount(autoBuyAmount + step)
	TweenService:Create(btnPlus, TweenInfo.new(0.08), {BackgroundColor3 = C.BORDER}):Play()
	task.delay(0.1, function()
		TweenService:Create(btnPlus, TweenInfo.new(0.1), {BackgroundColor3 = C.BG3}):Play()
	end)
end)


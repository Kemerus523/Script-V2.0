local TARGET_PARTS = {
	{ label = "Head",       part = "Head"             },
	{ label = "Torso",      part = "HumanoidRootPart" },
	{ label = "Left Arm",   part = "Left Arm"         },
	{ label = "Right Arm",  part = "Right Arm"        },
	{ label = "Left Leg",   part = "Left Leg"         },
	{ label = "Right Leg",  part = "Right Leg"        },
}

local selectedPartBtns = {}
local partBtnYStart = 74
local partBtnH = 26
local partBtnGap = 4
local colW   = 0.47
local colGap = 0.06

for i, opt in ipairs(TARGET_PARTS) do
	local col  = (i - 1) % 2
	local row  = math.floor((i - 1) / 2)
	local xPos = col == 0 and 0.03 or (0.03 + colW + colGap)
	local yPos = partBtnYStart + row * (partBtnH + partBtnGap)

	local btn = Instance.new("TextButton", aimCard)
	btn.Size             = UDim2.new(colW, 0, 0, partBtnH)
	btn.Position         = UDim2.new(xPos, 0, 0, yPos)
	btn.BackgroundColor3 = opt.part == aimbotTargetPart and C.ACCENT or C.BG3
	btn.Text             = opt.label
	btn.TextColor3       = opt.part == aimbotTargetPart and C.TEXT or C.MUTED
	btn.TextSize         = 11
	btn.Font             = Enum.Font.GothamBold
	btn.BorderSizePixel  = 0
	corner(btn, 5)
	local bs = Instance.new("UIStroke", btn)
	bs.Color    = opt.part == aimbotTargetPart and C.ACCENT or C.BORDER
	bs.Thickness = 1

	selectedPartBtns[i] = { btn = btn, stroke = bs, part = opt.part }

	btn.MouseButton1Click:Connect(function()
		aimbotTargetPart = opt.part
		for _, b in ipairs(selectedPartBtns) do
			local active = (b.part == aimbotTargetPart)
			TweenService:Create(b.btn, TweenInfo.new(0.15), {
				BackgroundColor3 = active and C.ACCENT or C.BG3,
				TextColor3       = active and C.TEXT   or C.MUTED,
			}):Play()
			b.stroke.Color = active and C.ACCENT or C.BORDER
		end
	end)
end


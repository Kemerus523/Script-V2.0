loginBtn.MouseButton1Click:Connect(function()
	if keybox.Text == KEY then
		TweenService:Create(loginFrame, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
		task.wait(0.4); showMenu()
	else
		keybox.Text = ""
		keybox.PlaceholderText = "Key Salah!"
		errLabel.Text = "Key tidak valid. Coba lagi."
		keyStroke.Color = C.DANGER
		task.wait(2)
		keybox.PlaceholderText = "Masukkan Key..."
		errLabel.Text = ""
		keyStroke.Color = C.BORDER
	end
end)


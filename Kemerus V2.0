-- Anti AFK
local vUser = game:GetService("VirtualUser")
plr.Idled:Connect(function()
	if state.AntiAFK then
		vUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
		task.wait(1)
		vUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
	end
end)

-- Auto Buy Loop
local RS = game:GetService("ReplicatedStorage")
local moneyChanged = RS:WaitForChild("RemoteEvents"):WaitForChild("MoneyChanged")

task.spawn(function()
	while true do
		task.wait(0.5)
		if autoBuyEnabled then
			statusBuyLbl.Text = "Status: ON  |  x" .. autoBuyAmount .. " per item"
			statusBuyLbl.TextColor3 = C.SUCCESS
			for _, item in ipairs(ITEMS) do
				for i = 1, autoBuyAmount do
					pcall(function()
						moneyChanged:FireServer(item.id)
					end)
					task.wait(0.05)
				end
			end
		else
			statusBuyLbl.Text = "Status: OFF"
			statusBuyLbl.TextColor3 = C.MUTED
		end
	end
end)

-- Speed Hack
RunService.Heartbeat:Connect(function()
	hum.WalkSpeed = state.SpeedHack and 48 or 16
end)

-- Noclip
RunService.Stepped:Connect(function()
	if state.Noclip then
		for _, part in ipairs(char:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanCollide = false
			end
		end
	end
end)

-- Fly
local flyBody
local function startFly()
	flyBody = Instance.new("BodyVelocity", hrp)
	flyBody.Velocity = Vector3.new(0,0,0)
	flyBody.MaxForce = Vector3.new(1e5,1e5,1e5)
end
local function stopFly()
	if flyBody then flyBody:Destroy() end
end

RunService.Heartbeat:Connect(function()
	if state.Fly then
		if not flyBody or not flyBody.Parent then startFly() end
		local cam = workspace.CurrentCamera
		flyBody.Velocity =
			cam.CFrame.LookVector * (UIS:IsKeyDown(Enum.KeyCode.W) and 60 or UIS:IsKeyDown(Enum.KeyCode.S) and -60 or 0)
			+ Vector3.new(0, UIS:IsKeyDown(Enum.KeyCode.Space) and 40 or UIS:IsKeyDown(Enum.KeyCode.LeftControl) and -40 or 0, 0)
	else
		stopFly()
	end
end)

-- ================================================
-- ESP SYSTEM
-- ================================================
local espObjects = {}

local function createESP(target)
	if target == plr then return end
	if espObjects[target] then return end
	local targetChar = target.Character
	if not targetChar then return end

	local highlight = Instance.new("Highlight")
	highlight.Name = "KemerusESP"
	highlight.Adornee = targetChar
	highlight.FillColor = Color3.new(1, 1, 1)
	highlight.FillTransparency = 0.85
	highlight.OutlineColor = Color3.new(1, 1, 1)
	highlight.OutlineTransparency = 0
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Parent = targetChar

	local head = targetChar:FindFirstChild("Head")
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "KemerusESPName"
	billboard.Size = UDim2.new(0, 120, 0, 30)
	billboard.StudsOffset = Vector3.new(0, 2.5, 0)
	billboard.AlwaysOnTop = true
	billboard.Adornee = head
	billboard.Parent = targetChar

	local nameLabel = Instance.new("TextLabel", billboard)
	nameLabel.Size = UDim2.new(1, 0, 1, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text = target.DisplayName .. "\n[" .. target.Name .. "]"
	nameLabel.TextColor3 = Color3.new(1, 1, 1)
	nameLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
	nameLabel.TextStrokeTransparency = 0
	nameLabel.TextSize = 13
	nameLabel.Font = Enum.Font.GothamBold

	espObjects[target] = {highlight = highlight, billboard = billboard}
end

local function removeESP(target)
	if espObjects[target] then
		pcall(function()
			espObjects[target].highlight:Destroy()
			espObjects[target].billboard:Destroy()
		end)
		espObjects[target] = nil
	end
end

local function clearAllESP()
	for target in pairs(espObjects) do removeESP(target) end
end

RunService.Heartbeat:Connect(function()
	if not state.ESP then clearAllESP(); return end
	for _, target in ipairs(Players:GetPlayers()) do
		if target ~= plr and target.Character then createESP(target) end
	end
	for target in pairs(espObjects) do
		if not target.Parent then removeESP(target) end
	end
end)

Players.PlayerRemoving:Connect(function(t) removeESP(t) end)

for _, target in ipairs(Players:GetPlayers()) do
	if target ~= plr then
		target.CharacterAdded:Connect(function()
			task.wait(1)
			if state.ESP then removeESP(target); createESP(target) end
		end)
	end
end

Players.PlayerAdded:Connect(function(target)
	target.CharacterAdded:Connect(function()
		task.wait(1)
		if state.ESP then removeESP(target); createESP(target) end
	end)
end)


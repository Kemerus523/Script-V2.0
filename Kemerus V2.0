local function showMenu()
	loginFrame.Visible = false
	menuFrame.Visible = true
	statusDot.BackgroundColor3 = C.SUCCESS
	statusTxt.Text = "CONNECTED  •  KEMERUS HUB"
	statusTxt.TextColor3 = C.SUCCESS

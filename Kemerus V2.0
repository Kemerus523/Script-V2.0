local menuFrame = Instance.new("Frame", frame)
menuFrame.Size = UDim2.new(1, 0, 1, -68)
menuFrame.Position = UDim2.new(0, 0, 0, 42)
menuFrame.BackgroundTransparency = 1
menuFrame.Visible = false

local tabBar = Instance.new("Frame", menuFrame)
tabBar.Size = UDim2.new(1, 0, 0, 34)
tabBar.BackgroundColor3 = C.BG3
tabBar.BorderSizePixel = 0
local tabLayout = Instance.new("UIListLayout", tabBar)
tabLayout.FillDirection = Enum.FillDirection.Horizontal
tabLayout.SortOrder = Enum.SortOrder.LayoutOrder

local tabNames = {"AUTO FARM", "TELEPORT", "MISC", "CREDITS"}
local tabFrames, tabBtns = {}, {}

local function switchTab(idx)
	for i, f in ipairs(tabFrames) do
		f.Visible = (i == idx)
		tabBtns[i].TextColor3 = (i == idx) and C.ACCENT or C.MUTED
	end
end

for i, name in ipairs(tabNames) do
	local btn = Instance.new("TextButton", tabBar)
	btn.Size = UDim2.new(0.25, 0, 1, 0)
	btn.BackgroundTransparency = 1
	btn.Text = name
	btn.TextSize = 10
	btn.Font = Enum.Font.GothamBold
	btn.TextColor3 = (i == 1) and C.ACCENT or C.MUTED
	btn.BorderSizePixel = 0
	btn.LayoutOrder = i
	tabBtns[i] = btn
	btn.MouseButton1Click:Connect(function() switchTab(i) end)
end

local function makeTabFrame()
	local f = Instance.new("ScrollingFrame", menuFrame)
	f.Size = UDim2.new(1, 0, 1, -34)
	f.Position = UDim2.new(0, 0, 0, 34)
	f.BackgroundTransparency = 1
	f.BorderSizePixel = 0
	f.ScrollBarThickness = 3
	f.ScrollBarImageColor3 = C.BORDER
	f.CanvasSize = UDim2.new(0, 0, 0, 0)
	f.AutomaticCanvasSize = Enum.AutomaticSize.Y
	local layout = Instance.new("UIListLayout", f)
	layout.Padding = UDim.new(0, 6)
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	local pad = Instance.new("UIPadding", f)
	pad.PaddingLeft = UDim.new(0, 12); pad.PaddingRight = UDim.new(0, 12)
	pad.PaddingTop = UDim.new(0, 10);  pad.PaddingBottom = UDim.new(0, 10)
	return f
end

local function makeToggle(parent, labelTxt, subTxt, stateKey, order, onToggle)
	local row = Instance.new("Frame", parent)
	row.Size = UDim2.new(1, 0, 0, 46)
	row.BackgroundColor3 = C.BG2
	row.BorderSizePixel = 0
	row.LayoutOrder = order
	corner(row)
	local rs = Instance.new("UIStroke", row)
	rs.Color = C.BORDER; rs.Thickness = 1

	local lbl = label(row, labelTxt, 13, C.TEXT, Enum.Font.GothamBold)
	lbl.Size = UDim2.new(0.65, 0, 0, 18)
	lbl.Position = UDim2.new(0, 12, 0, 7)
	local sub = label(row, subTxt, 11, C.MUTED, Enum.Font.Gotham)
	sub.Size = UDim2.new(0.65, 0, 0, 14)
	sub.Position = UDim2.new(0, 12, 0, 25)

	local pill = Instance.new("Frame", row)
	pill.Size = UDim2.new(0, 38, 0, 20)
	pill.Position = UDim2.new(1, -50, 0.5, -10)
	pill.BackgroundColor3 = state[stateKey] and C.TOGGLE_ON or C.TOGGLE_OFF
	pill.BorderSizePixel = 0
	corner(pill, 10)

	local knob = Instance.new("Frame", pill)
	knob.Size = UDim2.new(0, 14, 0, 14)
	knob.Position = state[stateKey] and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)
	knob.BackgroundColor3 = state[stateKey] and C.TEXT or C.MUTED
	knob.BorderSizePixel = 0
	corner(knob, 10)

	local btn = Instance.new("TextButton", row)
	btn.Size = UDim2.new(1, 0, 1, 0)
	btn.BackgroundTransparency = 1
	btn.Text = ""
	btn.MouseButton1Click:Connect(function()
		state[stateKey] = not state[stateKey]
		local on = state[stateKey]
		TweenService:Create(pill, TweenInfo.new(0.2), {BackgroundColor3 = on and C.TOGGLE_ON or C.TOGGLE_OFF}):Play()
		TweenService:Create(knob, TweenInfo.new(0.2), {
			Position = on and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7),
			BackgroundColor3 = on and C.TEXT or C.MUTED,
		}):Play()
		if onToggle then onToggle(on) end
	end)
end

local function makeActionBtn(parent, text, callback, order, accentColor)
	local btn = Instance.new("TextButton", parent)
	btn.Size = UDim2.new(1, 0, 0, 38)
	btn.BackgroundColor3 = C.BG2
	btn.Text = ""; btn.BorderSizePixel = 0; btn.LayoutOrder = order
	corner(btn)
	local s = Instance.new("UIStroke", btn); s.Color = C.BORDER

	local dotColor = accentColor or C.ACCENT
	local dot = Instance.new("Frame", btn)
	dot.Size = UDim2.new(0, 6, 0, 6); dot.Position = UDim2.new(0, 12, 0.5, -3)
	dot.BackgroundColor3 = dotColor; dot.BorderSizePixel = 0; corner(dot, 10)

	local lbl = label(btn, text, 13, C.TEXT, Enum.Font.GothamBold)
	lbl.Size = UDim2.new(1, -36, 1, 0); lbl.Position = UDim2.new(0, 26, 0, 0)
	lbl.TextXAlignment = Enum.TextXAlignment.Left

	btn.MouseButton1Click:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = C.BORDER}):Play()
		task.wait(0.1)
		TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = C.BG2}):Play()
		if callback then callback() end
	end)
	return btn
end

